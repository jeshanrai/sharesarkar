# Production (Render + Neon) — set these in the Render dashboard
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
JWT_SECRET=replace-with-a-long-random-string
FRONTEND_URL=https://your-frontend.vercel.app
NODE_ENV=production

# Optional — Render injects PORT automatically
# PORT=5000

# Local development (used only when DATABASE_URL is unset)
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sharesanskar

# Media library (image uploads)
# MEDIA_DRIVER=local
# Absolute path or repo-relative; defaults to "<backend>/uploads"
# MEDIA_DIR=/var/data/uploads
# URL prefix the static handler serves files from (default /uploads)
# MEDIA_PUBLIC_PATH=/uploads
# IMPORTANT: ensure MEDIA_DIR persists across restarts in production —
# the runtime does not check this. On ephemeral filesystems, point it at a
# mounted persistent disk or swap in an object-storage adapter.
